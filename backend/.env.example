# ──────────────────────────────────────────────────────────────────────────────
# CrowdControl Backend — Environment Variables
# Copy this file to `.env` and fill in values for your setup.
# `.env` is in .gitignore and must never be committed.
# ──────────────────────────────────────────────────────────────────────────────

# WebSocket server port (frontend ws.ts must match)
WS_PORT=5178

# Key injection mode: nodesender | nodesender_repeat | autohotkey
INJECTION_MODE=autohotkey

# AutoHotkey executable path (only required for INJECTION_MODE=autohotkey)
AHK_PATH="C:\Program Files\AutoHotkey\v2\AutoHotkey64.exe"

# WebSocket Authentication token
# If left blank or omitted, a secure 32-byte random token is generated at each
# startup. Set a fixed value here if you run the backend externally (not via
# Electron) so that both sides share the same token.
#
# Generate a strong token with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WS_TOKEN=

# TikTok session cookie  ← REQUIRED to connect without DEVICE_BLOCKED errors
# TikTok's Akamai CDN blocks unauthenticated WebSocket upgrades.
# You must provide a valid sessionid cookie from a logged-in TikTok browser session.
#
# How to get it:
#   1. Open https://www.tiktok.com in Chrome/Edge and log in.
#   2. Press F12 → Application tab → Cookies → https://www.tiktok.com
#   3. Find the cookie named "sessionid" and copy its Value.
#   4. Paste it below (no quotes needed).
#   5. The cookie expires when you log out, so refresh it if connections start failing.
TIKTOK_SESSION_ID=

# Optional: restrict key injection to a specific window by partial title/owner
# Leave blank to allow injection regardless of which window is focused.
TARGET_WINDOW_KEYWORD=
